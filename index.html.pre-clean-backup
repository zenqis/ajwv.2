  var msg=top.level==='overdue'
    ? 'Pengingat langganan: '+top.nama+' terlambat '+Math.abs(top.daysLeft)+' hari.'
    : (top.level==='today'
      ? 'Pengingat langganan: '+top.nama+' jatuh tempo hari ini.'
