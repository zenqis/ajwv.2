  }
  if(snap.hr.evaluations>0 && snap.hr.avgEvaluation>0 && snap.hr.avgEvaluation<75){
    addAlert('warning','Rata-rata evaluasi HR menurun','Nilai evaluasi rata-rata berada di bawah ambang aman.','hr','Cek karyawan prioritas dan tindakan coaching');
  }
  if(((_toolAutomationJobs||[]).filter(function(j){ return j&&j.channel==='agent'&&j.active; }).length)>0 && !((_toolAgentBridge&&_toolAgentBridge.endpoint)||'')){
    addAlert('warning','Automation agent aktif tanpa endpoint bridge','Ada job agent aktif tetapi endpoint bridge belum diisi.','ai','Lengkapi bridge atau pause job agent');
  }
  if(snap.finance.supplierDebtRows>0){
    addAlert('info','Ada hutang supplier aktif','Data hutang supplier masih aktif dan perlu dipantau rutin.','finance','Cek jatuh tempo dan coverage pembayaran');
  }
  if((snap.tools.refunds+snap.tools.complaints+snap.tools.requests)===0){
    addAlert('info','Belum ada tiket operasional aktif','Tools operasional saat ini relatif tenang.','tools','Pertahankan monitoring');
  }
  var totalCritical=alerts.filter(function(a){ return a.level==='critical'; }).length;
  var totalWarning=alerts.filter(function(a){ return a.level==='warning'; }).length;
  var decisionLevel=1;
  if(totalCritical>0) decisionLevel=Math.min(5,conf.autoLevel>=4?4:3);
  else if(totalWarning>0) decisionLevel=Math.min(4,Math.max(2,conf.autoLevel));
  else if((patterns.topActions||[]).length>=3) decisionLevel=Math.min(3,conf.autoLevel);
  var approvals=_ajwAIOSRead('ajw_aios_approvals',[]);
  var decisions=_ajwAIOSRead('ajw_aios_decisions',[]);
  var suggestions=[];
  if(patterns.topActions.length){
    suggestions.push({
      title:'Pola aktivitas berulang terdeteksi',
