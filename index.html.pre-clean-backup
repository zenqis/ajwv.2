function _toolsAiLooksFinal(kind,text){
  var t=String(text||'').trim();
  if(!t) return false;
  if(kind==='refund') return /pengembalian dana diproses/i.test(t);
  if(kind==='complaint') return /\*laporan komplain\*/i.test(t) || /\*pencatat:\*/i.test(t);
  if(kind==='request') return /permintaan request pembeli/i.test(t) || /permintaan ganti produk/i.test(t);
  return false;
}
function _toolsComposeWAText(kind,row){
  var ai=String(row&&row.aiAnalysis||'').trim();
  if(_toolsAiLooksFinal(kind, ai)) return ai;
  return kind==='refund'?_refundTemplate(row):(kind==='complaint'?_complaintTemplate(row):_requestTemplate(row));
}
function _toolsResolveMoonWAMediaUrl(row){
  var raw=String((row&&((row.imagePublicUrl||row.imageUrl||row.imageData)))||'').trim();
  if(!raw) return '';
  if(/^https?:\/\//i.test(raw)) return raw;
  if(/^data:image\//i.test(raw)) return raw;
  return '';
}
function _toolsMoonWAPayload(kind,row){
  var text=_toolsComposeWAText(kind,row);
  var receiver=String((row&&row.groupId)||_toolsGroupId(kind)||'').trim();
  var mediaUrl=_toolsResolveMoonWAMediaUrl(row);
  if(/^data:image\//i.test(mediaUrl) && mediaUrl.length>140000) mediaUrl='';
  if(mediaUrl){
    return {
      endpoint:MOONWA_ENDPOINTS.media,
      body:{
        api_key:_toolsMoonWAKey(),
        receiver:receiver,
        data:{
          url:mediaUrl,
          media_type:'image',
          caption:text
        }
      },
      mode:'media'
    };
  }
  return {
    endpoint:MOONWA_ENDPOINTS.message,
    body:{
      api_key:_toolsMoonWAKey(),
      receiver:receiver,
      data:{
        message:text
      }
    },
    mode:'text'
  };
}
