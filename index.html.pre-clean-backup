          h += '<td style="padding:6px 10px;border:1px solid var(--bd);text-align:right;color:'+(tx.netto>0?'#EF4444':'var(--tx3)')+'">'+( tx.netto>0?'Rp '+fmt(tx.netto):'-')+'</td>';
