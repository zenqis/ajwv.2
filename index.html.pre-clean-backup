async function _toolsPickingTriggerFromWeb(ev){
  if(_toolPickingUploading) return;
  var btn=document.getElementById('trigger-pickinglist-btn');
  var dryRun=!!(ev&&ev.shiftKey);
  var originalLabel=(btn&&btn.textContent)||'Trigger Picking List';
  var rows=_toolsPickingRowsMatrix();
  if(!rows.length){
    toast('Belum ada data picking untuk diproses','error',3200);
    return;
  }
  if(location && location.protocol==='file:'){
    _toolsPickingPushHistory('trigger','Lokal','Mode file:// terdeteksi, trigger endpoint dilewati','Menjalankan proses lokal Bundling & Satuan',rows.length);
    _toolsPickingSetProgress(true,22,'Mode lokal aktif','Website dibuka via file://, proses dijalankan lokal tanpa endpoint bridge.','info',false);
    toast('Mode lokal: trigger endpoint dilewati, proses lokal dijalankan','info',3600);
    await _toolsPickingRunTrigger();
    return;
  }
  _toolPickingUploading=true;
  if(btn){
    btn.disabled=true;
    btn.textContent=dryRun?'Dry Run...':'Trigger...';
  }
  _toolsPickingSetProgress(true,12,dryRun?'Dry Run Trigger Picking':'Trigger Picking List','Menyiapkan '+rows.length+' baris untuk diproses', 'info', false);
  try{
    var ctl=(typeof AbortController!=='undefined')?new AbortController():null;
    var timer=null;
    if(ctl){
      timer=setTimeout(function(){ try{ctl.abort();}catch(e){} },60000);
    }
    var resp=await fetch('/api/picking/trigger',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({dryRun:dryRun}),
      signal:ctl?ctl.signal:undefined
    });
    if(timer) clearTimeout(timer);
    var payload=null;
    var text='';
    try{ payload=await resp.json(); }catch(e){ text=await resp.text(); }
    if(!resp.ok || (payload&&payload.ok===false)){
      var em=(payload&&(payload.error||payload.message||payload.appsScriptResponse))||text||('HTTP '+resp.status);
      throw new Error(String(em||'Trigger gagal'));
    }
    var imported=_num(payload&&payload.imported)||rows.length;
    _toolsPickingPushHistory('trigger','Sukses',dryRun?'Dry run trigger endpoint':'Trigger endpoint',payload||text,imported);
    _toolsPickingSetProgress(true,100,dryRun?'Dry Run selesai':'Trigger selesai',(payload&&payload.message)?payload.message:('Imported '+fmt(imported)+' rows'),'success',true);
    if(!dryRun){
      _toolsPickingProcessData();
    }
    toast((payload&&payload.message)?payload.message:('Imported '+fmt(imported)+' rows'),'success',4200);
  }catch(err){
    var rawMsg=String(err&&err.message||err||'Trigger gagal');
    var msg=(/failed to fetch/i.test(rawMsg)?'Koneksi endpoint bridge belum aktif / terblokir browser':rawMsg);
    _toolsPickingPushHistory('trigger','Fallback','Endpoint trigger gagal, fallback ke proses lokal',msg,rows.length);
    _toolsPickingSetProgress(true,55,'Endpoint tidak aktif','Beralih ke proses lokal AJW: '+msg,'warn',false);
    try{
      await _toolsPickingRunTrigger();
      return;
    }catch(_e){
      _toolsPickingSetProgress(true,100,'Trigger gagal','Endpoint dan fallback lokal gagal: '+msg,'error',true);
      toast('Trigger gagal: '+msg,'error',5200);
    }
  }finally{
    _toolPickingUploading=false;
    if(btn){
      btn.disabled=false;
      btn.textContent=originalLabel;
    }
    _renderTools('pick');
  }
}
