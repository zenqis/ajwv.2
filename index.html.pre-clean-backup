/* ====== PAYROLL ====== */
function _payInt(v){return parseInt(v,10)||0}
function _payStdDays(info){
  var n=_payInt(info&&(info.hariKerjaStandar!=null?info.hariKerjaStandar:info.standarHariKerja));
  if(n>0)return n;
  return info&&info.tipe==='Bulanan'?26:6;
}
function _payBaseReference(info){
  return _payInt(info&&(info.gajiPokokRef!=null&&info.gajiPokokRef!==''?info.gajiPokokRef:info.gajiPokok));
}
function _payWorkedDays(info){
  if(!info)return null;
  var raw=String(info.hariKerja==null?'':info.hariKerja).trim();
  if(raw==='')return null;
  var n=_payInt(raw);
  return n<0?0:n;
}
function _paySalaryMeta(info){
  var baseRef=_payBaseReference(info), stdDays=_payStdDays(info), workedDays=_payWorkedDays(info);
  var usedDays=workedDays==null?stdDays:Math.max(0,Math.min(workedDays,stdDays));
  var proratedBase=workedDays==null?baseRef:Math.round((baseRef/stdDays)*usedDays);
  var potHariOff=workedDays==null?0:Math.max(0,baseRef-proratedBase);
  var potManual=_payInt(info&&info.potManual);
  return {baseRef:baseRef,stdDays:stdDays,workedDays:workedDays,usedDays:usedDays,proratedBase:proratedBase,potHariOff:potHariOff,potManual:potManual,potAbsenTotal:potHariOff+potManual};
}
function calcPay(){
