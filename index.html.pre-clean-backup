function _toolsBlastNormalizePhone(val){
  var raw=String(val||'').trim();
  if(!raw) return '';
  if(/[*xX]/.test(raw)) return '';
  if(/@(c|g)\.us$/i.test(raw)) return raw;
  var digits=raw.replace(/[^\d]/g,'');
  if(digits.length<10) return '';
  if(!digits) return '';
  if(digits.indexOf('0')===0) digits='62'+digits.slice(1);
  if(digits.indexOf('62')!==0) digits='62'+digits;
  if(digits.length<11) return '';
  return digits+'@c.us';
}
function _toolsBlastPhoneRawAllowed(val){
  var raw=String(val||'').trim();
  if(!raw) return false;
  if(/[*xX]/.test(raw)) return false;
  var digits=raw.replace(/[^\d]/g,'');
  return digits.length>=10;
}
function _toolsBlastNormalizePhoneList(val){
  return String(val||'')
    .split(/[\n,;]+/)
