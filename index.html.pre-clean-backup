      benefit:'Bisa dijadikan automation / shortcut agar owner lebih hemat waktu.'
    });
  }
  if(snap.analytics.topMarketplace && snap.analytics.topMarketplace.label && snap.analytics.topMarketplace.label!=='-'){
    suggestions.push({
      title:'Marketplace dominan terdeteksi',
      detail:snap.analytics.topMarketplace.label+' saat ini paling dominan dengan '+snap.analytics.topMarketplace.count+' data.',
      benefit:'Bisa dipakai sebagai fokus promo, stok, dan analisa layanan.'
    });
  }
  if(snap.finance.assetRows>0){
    suggestions.push({
      title:'Aset sudah cukup untuk pemantauan trend',
      detail:'Data aset sudah tersedia dan siap dipakai untuk pembacaan perubahan nilai dari waktu ke waktu.',
      benefit:'Memudahkan owner memantau pertumbuhan modal dan aset produktif.'
    });
