        (d.bayar||[]).forEach(function(b){txns.push({tgl:b.tgl,noDok:'',ket:b.keterangan,kode:'',netto:0,bayar:parseFloat(b.jumlah)||0,isBayar:true,bukti:b.bukti||''});});
