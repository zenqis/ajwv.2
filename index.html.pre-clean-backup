function _toolsPickingProcessData(){
  var expanded=[];
  (_toolPickingRows||[]).forEach(function(r){
    var nomor=String(r.nomorPesanan||'').trim();
    if(!nomor) return;
    var jumlah=Math.max(1,_num(r.jumlah)||1);
    for(var j=0;j<jumlah;j++){
      expanded.push({
        done:false,
        nomorPesanan:nomor,
        tautanGambar:String(r.tautanGambar||'').trim(),
        namaProduk:String(r.namaProduk||'').trim(),
        sku:String(r.sku||'').trim(),
        namaVariasi:String(r.namaVariasi||'').trim(),
        marketplace:String(r.marketplace||'').trim()
      });
    }
  });
  var orderMap={};
  expanded.forEach(function(r){
    if(!orderMap[r.nomorPesanan]) orderMap[r.nomorPesanan]=[];
    orderMap[r.nomorPesanan].push(r);
  });
  var bundling=[];
  var satuan=[];
  Object.keys(orderMap).forEach(function(nomor){
    var items=orderMap[nomor];
    items.sort(function(a,b){ return String(a.namaProduk||'').localeCompare(String(b.namaProduk||''),'id'); });
    if(items.length>1){
      bundling.push({orderNumber:nomor,items:items});
    }else{
      satuan.push(items[0]);
    }
  });
  satuan.sort(function(a,b){ return String(a.namaProduk||'').localeCompare(String(b.namaProduk||''),'id'); });
  bundling.sort(function(a,b){ return String(a.orderNumber||'').localeCompare(String(b.orderNumber||''),'id'); });
  _toolPickingProcessed={bundling:bundling,satuan:satuan,processedAt:isoNow()};
  _toolsPickingPushHistory('process','Sukses','Memproses data menjadi Bundling dan Satuan','Lokal AJW • '+bundling.length+' bundling • '+satuan.length+' satuan',expanded.length);
  _toolsSave();
  toast('Picking List berhasil diproses','success',3200);
  _renderTools('pick');
}
