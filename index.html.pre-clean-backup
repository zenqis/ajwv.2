function _ajwAIOSLearnPatterns(logs){
  logs=_ajwAIOSRead('ajw_aios_activity_log',logs||[]);
  var actionMap={}, tabMap={};
  logs.forEach(function(it){
    var label=String(it&&it.label||it&&it.type||'-').trim();
    var tab=String(it&&it.mainTab||'-').trim();
    if(label) actionMap[label]=(actionMap[label]||0)+1;
    if(tab && tab!=='-') tabMap[tab]=(tabMap[tab]||0)+1;
  });
  function top(map, limit){
    return Object.keys(map).sort(function(a,b){ return map[b]-map[a]; }).slice(0,limit||5).map(function(k){
      return {label:k,count:map[k],score:Math.min(100,map[k]*10)};
    });
  }
  var out={ topActions:top(actionMap,6), topTabs:top(tabMap,6), learnedAt:isoNow() };
  _ajwAIOSWrite('ajw_aios_patterns',out);
  return out;
}
