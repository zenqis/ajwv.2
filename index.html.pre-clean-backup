    .forEach(function(d){
      (d.bayar||[]).forEach(function(b){
        all.push({tgl:b.tgl,ket:b.keterangan,jml:parseFloat(b.jumlah)||0,sup:d.namaSupplier||'Golden Fish',periode:(d.bulan||'')+' '+(d.tahun||''),bukti:b.bukti||''});
