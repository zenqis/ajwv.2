        h += '</div>';
        h += '<div style="display:flex;gap:5px;flex-wrap:wrap">';
        if(!lunas) h += '<button onclick="_openBayarModal('+oi+')" class="btnsm" style="background:#10B981;font-size:10px">+Bayar</button>';
