function _ajwAIOSCapture(type, payload){
  var conf=_ajwAIOSConfig();
  if(!conf.enabled || !conf.activityCapture) return;
  var logs=_ajwAIOSRead('ajw_aios_activity_log',[]);
  var item=Object.assign({
