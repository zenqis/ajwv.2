PORT=3010
APP_BASE_URL=http://localhost:3010
DB_PATH=./data/shopee_chat.json

# Shopee Open Platform credentials
SHOPEE_PARTNER_ID=YOUR_PARTNER_ID
SHOPEE_PARTNER_KEY=YOUR_PARTNER_KEY
SHOPEE_REDIRECT_PATH=/api/shopee/oauth/callback

# Optional: force test environment
SHOPEE_ENV=live

# Live push callback verification secret (from Shopee console)
LIVE_PUSH_PARTNER_KEY=YOUR_LIVE_PUSH_PARTNER_KEY
