function _toolsProductModalChanges(){
  var rows=_toolsProductCurrentRows();
  var changes=[];
  rows.forEach(function(r){
    var hist=Array.isArray(r.modalHistory)?r.modalHistory.filter(Boolean):[];
    if(hist.length<2) return;
    var sorted=hist.slice().sort(function(a,b){ return String(a.at||'').localeCompare(String(b.at||'')); });
    var prev=sorted[sorted.length-2], cur=sorted[sorted.length-1];
    var fromVal=_num(prev&&prev.value), toVal=_num(cur&&cur.value);
    if(fromVal===toVal) return;
    var delta=toVal-fromVal;
    changes.push({
      id:r.id,
      sku:r.sku||'-',
      title:r.title||'-',
      from:fromVal,
      to:toVal,
      delta:delta,
      pct:fromVal?((delta/fromVal)*100):0,
      updatedAt:r.updatedAt||r.importedAt||'',
      category1:r.category1||'',
      category2:r.category2||''
    });
  });
  var ui=_toolsProductUi();
  changes=changes.filter(function(r){
    var c1=String(r.category1||'').trim();
    var c2=String(r.category2||'').trim();
    var ok1=(ui.cat1==='all')||(ui.cat1==='__NONE__'?!c1:c1===ui.cat1);
    var ok2=(ui.cat2==='all')||(ui.cat2==='__NONE__'?!c2:c2===ui.cat2);
