function _toolsBlastGroupRows(rows){
  var map={};
  (rows||[]).forEach(function(r,idx){
    var orderNo=String(r['Nomor Pesanan']||r['nomor pesanan']||r.order_number||r.orderNo||'').trim();
    var resi=String(r['Nomor Resi']||r['nomor resi']||r.tracking_number||r.resi||'').trim();
    var nama=String(r['Nama Penerima']||r['nama penerima']||r.receiver_name||r.nama_penerima||'').trim();
    var alamat=String(r['Alamat Lengkap']||r['alamat lengkap']||r.address||r.alamat_lengkap||'').trim();
    var produk=String(r['Nama Produk']||r['nama produk']||r.product_name||r.nama_produk||'').trim();
    var variasi=String(r['Nama Variasi']||r['nama variasi']||r.variant_name||r.nama_variasi||'').trim();
    var kirim=String(r['Nama Jasa Kirim']||r['nama jasa kirim']||r.shipping_service||r.nama_jasa_kirim||'').trim();
    var subtotal=String(r['Subtotal Produk']||r['subtotal produk']||r.product_subtotal||r.subtotal_produk||'').trim();
    var bayar=String(r['Metode Pembayaran']||r['metode pembayaran']||r.payment_method||r.metode_pembayaran||'').trim();
    var marketplace=String(r['Marketplace']||r['marketplace']||r.marketplace||'').trim();
    var phone=String(r['Nomor Telepon']||r['nomor telepon']||r.phone||r.nomor_telepon||'').trim();
    if(!orderNo && !phone && !produk) return;
    var key=orderNo || ('noorder_'+idx);
    if(!map[key]){
      map[key]={
        id:'blast_'+Date.now()+'_'+idx+'_'+Math.random().toString(36).slice(2,6),
        orderNo:orderNo,
        trackingNo:resi,
        namaPenerima:nama,
        alamatLengkap:alamat,
        namaJasaKirim:kirim,
        subtotalProduk:subtotal,
        metodePembayaran:bayar,
        marketplace:marketplace,
        nomorTeleponRaw:phone,
        nomorTelepon:_toolsBlastNormalizePhone(phone),
        detailProduk:[],
        message:'',
        status:'ready',
        updatedAt:isoNow(),
        error:''
      };
    }
    if(produk || variasi){
      map[key].detailProduk.push({
        produk:produk,
        variasi:variasi
      });
    }
    if(!map[key].trackingNo && resi) map[key].trackingNo=resi;
    if(!map[key].namaPenerima && nama) map[key].namaPenerima=nama;
    if(!map[key].alamatLengkap && alamat) map[key].alamatLengkap=alamat;
    if(!map[key].namaJasaKirim && kirim) map[key].namaJasaKirim=kirim;
    if(!map[key].subtotalProduk && subtotal) map[key].subtotalProduk=subtotal;
    if(!map[key].metodePembayaran && bayar) map[key].metodePembayaran=bayar;
    if(!map[key].marketplace && marketplace) map[key].marketplace=marketplace;
    if(!map[key].nomorTelepon && phone) map[key].nomorTelepon=_toolsBlastNormalizePhone(phone);
    if(!map[key].nomorTeleponRaw && phone) map[key].nomorTeleponRaw=phone;
  });
  return Object.keys(map).map(function(k){
    var row=map[k];
    row.message=_toolsBlastComposeMessage(row);
    return row;
  });
}
