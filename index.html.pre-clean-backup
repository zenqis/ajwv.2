  var monitorCards=[
    {title:'HR',value:snap.hr.employees+' karyawan',meta:snap.hr.evaluations+' evaluasi • avg '+(snap.hr.avgEvaluation?snap.hr.avgEvaluation.toFixed(1):'-'),status:(snap.hr.avgEvaluation && snap.hr.avgEvaluation<75)?'warning':'active'},
    {title:'Finance',value:'Rp '+fmt(snap.finance.incomeTotal),meta:'Expense Rp '+fmt(snap.finance.expenseTotal),status:(snap.finance.expenseTotal>snap.finance.incomeTotal && snap.finance.incomeTotal>0)?'critical':'active'},
    {title:'Tools',value:(snap.tools.refunds+snap.tools.complaints+snap.tools.requests)+' tiket',meta:snap.tools.refunds+' refund • '+snap.tools.complaints+' komplain',status:snap.tools.complaints>=conf.complaintLimit?'warning':'active'},
    {title:'Analytics',value:snap.analytics.customers+' customer',meta:snap.analytics.topProvince.label+' • '+snap.analytics.topMarketplace.label,status:'active'},
    {title:'Development',value:snap.development.tasks+' task',meta:snap.development.ideas+' ide • '+snap.development.documents+' dokumen',status:'active'}
  ];
  var model={
    generatedAt:isoNow(),
    generatedLabel:_ajwAIOSNowLabel(),
    config:conf,
    snapshot:snap,
    alerts:alerts,
    approvals:approvals,
    decisions:decisions,
    changes:changes,
    activity:logs.slice(0,12),
    patterns:patterns,
    suggestions:suggestions,
    monitorCards:monitorCards,
    systemStatus:{
      ai:conf.enabled?'ACTIVE':'OFF',
      autoMonitor:conf.autoMonitor?'ON':'OFF',
      activityCapture:conf.activityCapture?'ON':'OFF',
      learning:conf.learning?'ON':'OFF',
      automationLevel:decisionLevel
    }
  };
  _ajwAIOSWrite('ajw_aios_last_model',model);
