function _ajwAIOSApprove(id, verdict){
  var approvals=_ajwAIOSRead('ajw_aios_approvals',[]);
  var decisions=_ajwAIOSRead('ajw_aios_decisions',[]);
  var item=null;
  approvals=approvals.filter(function(a){
    if(a.id===id){ item=a; return false; }
    return true;
  });
  if(item){
    item.verdict=verdict||'approved';
    item.decidedAt=isoNow();
    item.decidedLabel=_ajwAIOSNowLabel();
    decisions.unshift(item);
    if(decisions.length>120) decisions=decisions.slice(0,120);
    _ajwAIOSWrite('ajw_aios_decisions',decisions);
    _ajwAIOSCapture('approval_'+(verdict||'approved'),{label:item.title||'Approval', value:item.module||'-'});
  }
  _ajwAIOSWrite('ajw_aios_approvals',approvals);
  try{ toast('Approval '+(verdict==='rejected'?'ditolak':'disetujui'),'success',2200); }catch(e){}
  try{ if(window._activeTab==='ai') _renderAI(window._aiSub||'dash'); }catch(_e){}
}
function _ajwAIOSQueueApproval(title, detail, module, risk){
  var conf=_ajwAIOSConfig();
  if(!conf.enabled) return null;
  var approvals=_ajwAIOSRead('ajw_aios_approvals',[]);
  var exists=approvals.some(function(a){ return a.title===title && a.detail===detail; });
  if(exists) return null;
  var item={
    id:'apv_'+Date.now()+'_'+Math.random().toString(36).slice(2,6),
    ts:isoNow(),
    tsLabel:_ajwAIOSNowLabel(),
    title:title,
    detail:detail,
    module:module||'system',
    risk:risk||'medium'
  };
  approvals.unshift(item);
  if(approvals.length>80) approvals=approvals.slice(0,80);
  _ajwAIOSWrite('ajw_aios_approvals',approvals);
  return item;
}
function _ajwAIOSMountCapture(){
  if(window._ajwAIOSCaptureMounted) return;
  window._ajwAIOSCaptureMounted=true;
  document.addEventListener('click',function(ev){
    try{
      var el=ev.target&&ev.target.closest?ev.target.closest('button,a,[role=\"button\"]'):null;
      if(!el) return;
      var label=_ajwAIOSShortText(el.innerText||el.textContent||el.getAttribute('aria-label')||el.id||'klik',70);
      if(!label) return;
      _ajwAIOSCapture('click',{label:label});
    }catch(e){}
  },true);
  document.addEventListener('change',function(ev){
    try{
      var el=ev.target;
      if(!el || _ajwAIOSIsSensitive(el)) return;
      var label=_ajwAIOSShortText(el.getAttribute('data-label')||el.name||el.id||el.placeholder||'input',60);
      var value=(el.tagName==='SELECT')?(el.options[el.selectedIndex]&&el.options[el.selectedIndex].text||el.value):el.value;
      _ajwAIOSCapture('change',{label:label,value:_ajwAIOSShortText(value,60)});
    }catch(e){}
  },true);
}
function _ajwAIOSBoot(){
  if(window._ajwAIOSBooted) return;
