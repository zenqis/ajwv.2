syncAllToSupabase = function(silent){
  if(!SB.init()){ if(!silent) toast('Supabase belum dikonfigurasi', 'error'); return Promise.reject('not configured'); }
  if(!silent) toast('Menyinkronkan ke Supabase...', 'info', 8000);
  var tasks = [];
