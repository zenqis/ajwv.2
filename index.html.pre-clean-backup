function _toolsPickingSheetRowSignature(row, headers){
  headers=Array.isArray(headers)?headers:[];
  return headers.map(function(h){ return String((row&&row[h])==null?'':row[h]); }).join(' || ');
}
function _toolsPickingDiffSnapshot(nextRows, prevRows, headers){
  nextRows=Array.isArray(nextRows)?nextRows:[];
  prevRows=Array.isArray(prevRows)?prevRows:[];
  headers=Array.isArray(headers)?headers:[];
  var out=[], changed=0, added=0, removed=0;
  for(var i=0;i<nextRows.length;i++){
    var next=nextRows[i]||{};
    var prev=prevRows[i]||null;
    var status='stable';
    if(!prev){ status='new'; added++; }
    else if(_toolsPickingSheetRowSignature(next,headers)!==_toolsPickingSheetRowSignature(prev,headers)){ status='changed'; changed++; }
    out.push({status:status,data:next,index:i});
  }
  if(prevRows.length>nextRows.length) removed=prevRows.length-nextRows.length;
  return {rows:out, changed:changed, added:added, removed:removed};
}
