function _toolsBlastMarketingNextRun(job, now){
  var base=now instanceof Date?now:new Date();
  var hhmm=String(job.time||'09:00').split(':');
  var hour=Number(hhmm[0]||9), minute=Number(hhmm[1]||0);
  if(job.kind==='date'){
    var d=new Date(String(job.date||''));
    if(isNaN(d.getTime())) return '';
    d.setHours(hour, minute, 0, 0);
    return d.toISOString();
  }
  if(job.kind==='weekly'){
    var days=['sun','mon','tue','wed','thu','fri','sat'];
    var target=days.indexOf(String(job.weekday||'mon'));
    if(target<0) target=1;
    var d2=new Date(base); d2.setHours(hour, minute, 0, 0);
    var delta=(target-d2.getDay()+7)%7;
    if(delta===0 && d2.getTime()<=base.getTime()) delta=7;
    d2.setDate(d2.getDate()+delta);
    return d2.toISOString();
  }
  var day=Math.max(1, Math.min(31, Number(job.monthday||1)||1));
  var d3=new Date(base.getFullYear(), base.getMonth(), day, hour, minute, 0, 0);
  if(d3.getTime()<=base.getTime()) d3=new Date(base.getFullYear(), base.getMonth()+1, day, hour, minute, 0, 0);
  return d3.toISOString();
}
