function gc(s){if(s>=3.5)return{bg:'#E8F5E9',fg:'#2E7D32',dbg:'#388E3C'};if(s>=3)return{bg:'#DBEAFE',fg:'#1565C0',dbg:'#1976D2'};if(s>=2)return{bg:'#FFFDE7',fg:'#F57F17',dbg:'#F9A825'};return{bg:'#FFEBEE',fg:'#C62828',dbg:'#D32F2F'}}
