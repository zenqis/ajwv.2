function _toolsAutomationNextRun(job, fromDate){
  var j=job||{}, now=fromDate?new Date(fromDate):new Date();
  var time=String(j.runTime||'09:00').trim()||'09:00';
  var hh=parseInt(time.split(':')[0]||'9',10), mm=parseInt(time.split(':')[1]||'0',10);
  if(!isFinite(hh)) hh=9; if(!isFinite(mm)) mm=0;
  if(j.scheduleType==='once'){
    if(!j.runDate) return '';
    return new Date(j.runDate+'T'+String(hh).padStart(2,'0')+':'+String(mm).padStart(2,'0')+':00').toISOString();
  }
  if(j.scheduleType==='interval'){
    var mins=Math.max(5,_num(j.everyMinutes)||60);
    var base=j.lastRunAt?new Date(j.lastRunAt):now;
    if(isNaN(base.getTime())) base=now;
    return new Date(base.getTime()+mins*60000).toISOString();
  }
  var next=new Date(now);
  next.setSeconds(0,0);
  next.setHours(hh,mm,0,0);
  if(j.scheduleType==='weekly'){
    var wd=parseInt(j.weekday||1,10);
    if(!isFinite(wd)) wd=1;
    var jsDay=next.getDay();
    var target=(wd%7);
    var diff=target-jsDay;
    if(diff<0 || (diff===0 && next<=now)) diff+=7;
    next.setDate(next.getDate()+diff);
    return next.toISOString();
  }
  if(next<=now) next.setDate(next.getDate()+1);
  return next.toISOString();
}
