function _toolsBridgeResponseText(payload){
  if(payload==null) return '';
  if(typeof payload==='string') return payload.trim();
  if(Array.isArray(payload)) return payload.map(_toolsBridgeResponseText).filter(Boolean).join('\n').trim();
  if(payload.output_text && typeof payload.output_text==='string' && payload.output_text.trim()) return payload.output_text.trim();
  if(payload.answer && typeof payload.answer==='string' && payload.answer.trim()) return payload.answer.trim();
  if(payload.final && typeof payload.final==='string' && payload.final.trim()) return payload.final.trim();
  if(Array.isArray(payload.choices) && payload.choices[0]){
    var choice=payload.choices[0];
    if(choice.message && typeof choice.message.content==='string' && choice.message.content.trim()) return choice.message.content.trim();
    if(choice.text && typeof choice.text==='string' && choice.text.trim()) return choice.text.trim();
  }
  if(Array.isArray(payload.output)){
    var outParts=payload.output.map(function(item){
      if(item==null) return '';
      if(typeof item==='string') return item.trim();
      if(Array.isArray(item.content)){
        return item.content.map(function(bit){
          if(!bit) return '';
          if(typeof bit==='string') return bit.trim();
          if(typeof bit.text==='string' && bit.text.trim()) return bit.text.trim();
          if(typeof bit.output_text==='string' && bit.output_text.trim()) return bit.output_text.trim();
          if(typeof bit.value==='string' && bit.value.trim()) return bit.value.trim();
          return '';
        }).filter(Boolean).join('\n');
      }
      return _toolsBridgeResponseText(item);
    }).filter(Boolean).join('\n').trim();
    if(outParts) return outParts;
  }
  if(Array.isArray(payload.content)){
    var contentParts=payload.content.map(function(item){
      if(!item) return '';
      if(typeof item==='string') return item.trim();
      if(typeof item.text==='string' && item.text.trim()) return item.text.trim();
      if(typeof item.output_text==='string' && item.output_text.trim()) return item.output_text.trim();
      if(typeof item.value==='string' && item.value.trim()) return item.value.trim();
      return '';
    }).filter(Boolean).join('\n').trim();
    if(contentParts) return contentParts;
  }
  var keys=['output','response','message','content','result','text','reply','summary'];
  for(var i=0;i<keys.length;i++){
    var v=payload[keys[i]];
    if(typeof v==='string' && v.trim()) return v.trim();
    if(v && typeof v==='object'){
      var nested=_toolsBridgeResponseText(v);
      if(nested) return nested;
    }
  }
  if(payload.data){
    var nestedData=_toolsBridgeResponseText(payload.data);
    if(nestedData) return nestedData;
  }
  return '';
}
function _toolsBridgeResponseMeta(payload){
  if(!payload || typeof payload!=='object') return '';
  var lines=[];
  function add(label, value){
    if(value==null) return;
    var txt=String(value).trim();
    if(!txt) return;
    lines.push(label+': '+txt);
  }
  add('Status', payload.status||payload.state);
  add('Message', payload.message && typeof payload.message!=='object' ? payload.message : '');
  add('Job ID', payload.job_id||payload.jobId||payload.task_id||payload.taskId||payload.run_id||payload.runId||payload.id);
  add('Queue', payload.queue||payload.queue_name);
  add('Accepted', payload.accepted);
  add('Success', payload.success);
  add('Mode', payload.mode||payload.requested_mode);
  if(payload.data && typeof payload.data==='object'){
    add('Data Status', payload.data.status||payload.data.state);
    add('Data Job ID', payload.data.job_id||payload.data.jobId||payload.data.task_id||payload.data.taskId||payload.data.run_id||payload.data.runId);
  }
  return lines.filter(Boolean).join('\n').trim();
}
function _toolsBridgeResponsePretty(payload){
