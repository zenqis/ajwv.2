/* ──── SUPABASE DELETE (if not already defined) ──── */
if(typeof sbDeleteRecord === 'undefined'){
  function sbDeleteRecord(table, id){
    var cfg = getCfg();
    if(!cfg.supabaseUrl || !cfg.supabaseKey) return;
    fetch(cfg.supabaseUrl+'/rest/v1/'+table+'?id=eq.'+id, {
      method:'DELETE',
