    tsLabel:_ajwAIOSNowLabel(),
    type:type||'event',
    mainTab:(typeof _activeTab!=='undefined'&&_activeTab)||'-',
    aiTab:(window._aiSub||'-')
  },payload||{});
  var last=logs[0];
  if(last && last.type===item.type && last.label===item.label && last.value===item.value && Math.abs(new Date(item.ts)-new Date(last.ts))<4000){
    return;
  }
  logs.unshift(item);
  if(logs.length>300) logs=logs.slice(0,300);
  _ajwAIOSWrite('ajw_aios_activity_log',logs);
